GROQ_API_KEY=your_groq_key_here
LLMWHISPERER_API_KEY=your_llmwhisperer_key_here

# PDF extractor routing
PDF_EXTRACTOR_PROVIDER=docstruct
DOCSTRUCT_ROOT=
DOCSTRUCT_PYTHON=
DOCSTRUCT_MODE=standard
DOCSTRUCT_DETECTOR=stub
DOCSTRUCT_TIMEOUT_SEC=120
DOCSTRUCT_MIN_CHARS=80

# Structurer options
USE_MOCK_DATA=false
STRUCTURER_MODEL=llama-3.3-70b-versatile
STRUCTURER_MAX_DOC_CHARS=12000
STRUCTURER_BUNDLE_MAX_TOTAL_CHARS=30000
STRUCTURER_USE_BUNDLE_FIRST=true
